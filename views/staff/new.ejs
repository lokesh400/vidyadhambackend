<h2 class="text-2xl font-semibold mb-4">Add Staff</h2>

<form action="/admin/staff/add" method="POST" enctype="multipart/form-data" class="bg-white p-6 rounded-xl shadow border border-slate-200 space-y-6">
  <div class="grid md:grid-cols-3 gap-4">
    <input name="name" placeholder="Full Name" class="border p-2.5 rounded" />
    <input name="employeeId" placeholder="Employee ID" class="border p-2.5 rounded" />
    <input name="fatherName" placeholder="Father Name" class="border p-2.5 rounded" />
    <input name="motherName" placeholder="Mother Name" class="border p-2.5 rounded" />
    <input name="designation" placeholder="Designation" class="border p-2.5 rounded" />
    <input name="department" placeholder="Department" class="border p-2.5 rounded" />
    <input type="date" name="joiningDate" class="border p-2.5 rounded" />
    <input name="salary" placeholder="Salary" class="border p-2.5 rounded" />
    <input name="mobileNumber" placeholder="Mobile Number" class="border p-2.5 rounded" />
    <input name="phone" placeholder="Alternate Phone" class="border p-2.5 rounded" />
    <input name="email" placeholder="Email Address" class="border p-2.5 rounded" />
    <input name="aadhaarNumber" placeholder="Aadhaar Number" class="border p-2.5 rounded" />
    <input name="panNumber" placeholder="PAN Number" class="border p-2.5 rounded" />
    <select name="status" class="border p-2.5 rounded">
      <option value="Active">Active</option>
      <option value="Inactive">Inactive</option>
    </select>
  </div>

  <div>
    <label class="block mb-1 text-sm font-semibold text-slate-700">Link Existing Users (Optional)</label>
    <button
      type="button"
      id="openUserPickerBtn"
      class="px-4 py-2 rounded-lg border border-slate-300 text-sm font-semibold text-slate-700 hover:bg-slate-50"
    >
      Select Assigned Usernames
    </button>

    <select id="linkedUsersSelect" name="linkedUsers" multiple class="hidden">
      <% (eligibleUsers || []).forEach((user) => { %>
        <option value="<%= user._id %>"><%= user.name %> (<%= user.username %>) - <%= user.role %></option>
      <% }) %>
    </select>

    <div id="selectedUsernames" class="mt-3 flex flex-wrap gap-2"></div>
    <p class="text-xs text-slate-500 mt-1">Selection is optional. You can select multiple usernames.</p>

    <script id="eligibleUsersJson" type="application/json"><%- JSON.stringify(eligibleUsers || []) %></script>

    <div id="userPickerModal" class="hidden fixed inset-0 z-50 bg-black/40 p-4">
      <div class="bg-white max-w-2xl mx-auto rounded-xl shadow-xl border border-slate-200 p-4 md:p-5 mt-10">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-lg font-semibold">Select Assigned Usernames</h3>
          <button type="button" id="closeUserPickerBtn" class="text-slate-500 hover:text-slate-800">Close</button>
        </div>

        <input
          id="userPickerSearchInput"
          type="text"
          placeholder="Search by name, username, or role"
          class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm mb-3"
        />

        <div id="userPickerList" class="max-h-[420px] overflow-y-auto border border-slate-200 rounded-lg divide-y"></div>
      </div>
    </div>
  </div>

  <textarea name="address" placeholder="Address" class="w-full border p-2.5 rounded h-24"></textarea>

  <h3 class="text-lg font-semibold text-slate-800">Bank Details (Optional)</h3>
  <div class="grid md:grid-cols-4 gap-4">
    <input name="bankName" placeholder="Bank Name" class="border p-2.5 rounded" />
    <input name="accountHolderName" placeholder="Account Holder Name" class="border p-2.5 rounded" />
    <input id="accountNumber" name="accountNumber" placeholder="Account Number" class="border p-2.5 rounded" />
    <input id="confirmAccountNumber" name="confirmAccountNumber" placeholder="Confirm Account Number" class="border p-2.5 rounded" />
    <input name="ifscCode" placeholder="IFSC Code" class="border p-2.5 rounded" />
  </div>

  <h3 class="text-lg font-semibold text-slate-800">Documents (All Optional)</h3>
  <div class="grid md:grid-cols-3 gap-4 text-sm">
    <div><label class="block mb-1">Photo</label><input type="file" name="photo" /></div>
    <div><label class="block mb-1">Resume</label><input type="file" name="resume" /></div>
    <div><label class="block mb-1">Aadhaar File</label><input type="file" name="aadhaar" /></div>
    <div><label class="block mb-1">PAN File</label><input type="file" name="pan" /></div>
    <div><label class="block mb-1">Bank Account Photo</label><input type="file" name="bankAccountPhoto" /></div>
    <div><label class="block mb-1">Offer Letter</label><input type="file" name="offerLetter" /></div>
    <div><label class="block mb-1">Experience Letter</label><input type="file" name="experienceLetter" /></div>
    <div><label class="block mb-1">Other Document</label><input type="file" name="otherDocument" /></div>
  </div>

  <button class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700">
    Save Staff
  </button>
</form>

<script>
  const accountInput = document.getElementById("accountNumber");
  const confirmInput = document.getElementById("confirmAccountNumber");

  const openUserPickerBtn = document.getElementById("openUserPickerBtn");
  const closeUserPickerBtn = document.getElementById("closeUserPickerBtn");
  const userPickerModal = document.getElementById("userPickerModal");
  const userPickerSearchInput = document.getElementById("userPickerSearchInput");
  const userPickerList = document.getElementById("userPickerList");
  const selectedUsernames = document.getElementById("selectedUsernames");
  const linkedUsersSelect = document.getElementById("linkedUsersSelect");
  const eligibleUsers = JSON.parse(document.getElementById("eligibleUsersJson")?.textContent || "[]");

  const selectedUserSet = new Set(
    Array.from(linkedUsersSelect?.options || [])
      .filter((option) => option.selected)
      .map((option) => String(option.value))
  );

  const usersMap = new Map(eligibleUsers.map((user) => [String(user._id), user]));

  const syncSelectValues = () => {
    if (!linkedUsersSelect) return;
    Array.from(linkedUsersSelect.options).forEach((option) => {
      option.selected = selectedUserSet.has(String(option.value));
    });
  };

  const renderSelectedUsers = () => {
    if (!selectedUsernames) return;
    const selectedItems = Array.from(selectedUserSet)
      .map((id) => usersMap.get(id))
      .filter(Boolean);

    if (!selectedItems.length) {
      selectedUsernames.innerHTML = '<span class="text-sm text-slate-400">No usernames selected</span>';
      return;
    }

    selectedUsernames.innerHTML = selectedItems
      .map(
        (user) =>
          `<span class="inline-flex items-center gap-2 rounded-full bg-teal-50 text-teal-800 border border-teal-200 px-3 py-1 text-xs font-semibold">${user.username}<button type="button" data-remove-user="${user._id}" class="text-teal-700 hover:text-teal-900">x</button></span>`
      )
      .join("");
  };

  const renderUserPickerList = () => {
    if (!userPickerList) return;
    const query = (userPickerSearchInput?.value || "").trim().toLowerCase();

    const filtered = eligibleUsers.filter((user) => {
      const haystack = `${user.name || ""} ${user.username || ""} ${user.role || ""}`.toLowerCase();
      return haystack.includes(query);
    });

    if (!filtered.length) {
      userPickerList.innerHTML = '<p class="p-3 text-sm text-slate-500">No users found.</p>';
      return;
    }

    userPickerList.innerHTML = filtered
      .map((user) => {
        const isSelected = selectedUserSet.has(String(user._id));
        return `
          <div class="p-3 flex items-center justify-between gap-3">
            <div>
              <p class="font-semibold text-sm text-slate-800">${user.name || "-"} (${user.username || "-"})</p>
              <p class="text-xs text-slate-500">Role: ${user.role || "-"}</p>
            </div>
            <button
              type="button"
              data-toggle-user="${user._id}"
              class="px-3 py-1.5 rounded text-xs font-semibold ${isSelected ? "bg-emerald-100 text-emerald-700 border border-emerald-200" : "bg-blue-600 text-white"}"
            >
              ${isSelected ? "Added" : "Add Username"}
            </button>
          </div>
        `;
      })
      .join("");
  };

  userPickerList?.addEventListener("click", (event) => {
    const toggleButton = event.target.closest("[data-toggle-user]");
    if (!toggleButton) return;

    const userId = String(toggleButton.getAttribute("data-toggle-user"));
    if (!userId) return;

    if (selectedUserSet.has(userId)) {
      selectedUserSet.delete(userId);
    } else {
      selectedUserSet.add(userId);
    }

    syncSelectValues();
    renderSelectedUsers();
    renderUserPickerList();
  });

  selectedUsernames?.addEventListener("click", (event) => {
    const removeBtn = event.target.closest("[data-remove-user]");
    if (!removeBtn) return;
    const userId = String(removeBtn.getAttribute("data-remove-user"));
    selectedUserSet.delete(userId);
    syncSelectValues();
    renderSelectedUsers();
    renderUserPickerList();
  });

  openUserPickerBtn?.addEventListener("click", () => {
    userPickerModal?.classList.remove("hidden");
    renderUserPickerList();
    userPickerSearchInput?.focus();
  });

  closeUserPickerBtn?.addEventListener("click", () => userPickerModal?.classList.add("hidden"));
  userPickerModal?.addEventListener("click", (event) => {
    if (event.target === userPickerModal) {
      userPickerModal.classList.add("hidden");
    }
  });
  userPickerSearchInput?.addEventListener("input", renderUserPickerList);

  const syncAccountRequired = () => {
    const hasAccount = Boolean(accountInput?.value?.trim());
    const hasConfirm = Boolean(confirmInput?.value?.trim());

    if (accountInput) accountInput.required = hasConfirm;
    if (confirmInput) confirmInput.required = hasAccount;
  };

  accountInput?.addEventListener("input", syncAccountRequired);
  confirmInput?.addEventListener("input", syncAccountRequired);
  syncAccountRequired();

  syncSelectValues();
  renderSelectedUsers();
</script>
