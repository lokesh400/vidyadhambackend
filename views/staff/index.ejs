<div class="flex justify-between items-center mb-6">
  <div>
    <h2 class="text-2xl font-semibold">Staff Records</h2>
    <p class="text-sm text-gray-500">Manage employee details, documents, and active status.</p>
  </div>
  <a href="/admin/staff/new" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
    + Add Staff
  </a>
</div>

<div class="overflow-x-auto bg-white rounded-xl shadow border border-slate-200">
  <table class="w-full min-w-[1000px] text-sm">
    <thead class="bg-slate-50 text-slate-700">
      <tr>
        <th class="p-3 text-left">Name</th>
        <th class="p-3 text-left">Username</th>
        <th class="p-3 text-left">Mobile</th>
        <th class="p-3 text-left">Department</th>
        <th class="p-3 text-left">Designation</th>
        <th class="p-3 text-left">Status</th>
        <th class="p-3 text-left">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!staff.length) { %>
        <tr>
          <td colspan="7" class="p-8 text-center text-gray-500">No staff records found.</td>
        </tr>
      <% } %>

      <% staff.forEach((s) => { %>
        <tr class="border-t hover:bg-slate-50">
          <td class="p-3 font-semibold text-slate-900"><%= s.name || '-' %></td>
          <td class="p-3 text-slate-700"><%= s.username || '-' %></td>
          <td class="p-3 text-slate-700"><%= s.mobileNumber || s.phone || '-' %></td>
          <td class="p-3 text-slate-700"><%= s.department || '-' %></td>
          <td class="p-3 text-slate-700"><%= s.designation || '-' %></td>
          <td class="p-3">
            <span class="px-2 py-1 rounded-full text-xs font-semibold <%= s.status === 'Active' ? 'bg-green-100 text-green-700' : 'bg-gray-200 text-gray-700' %>">
              <%= s.status %>
            </span>
          </td>
          <td class="p-3">
            <div class="flex gap-2 items-center">
              <a href="/admin/staff/<%= s._id %>" class="px-3 py-1.5 border border-blue-200 bg-blue-50 text-blue-700 rounded text-xs font-semibold">View</a>
              <form action="/admin/staff/<%= s._id %>/toggle-status" method="POST" class="inline">
                <input type="hidden" name="redirectTo" value="/admin/staff" />
                <button class="px-3 py-1.5 border rounded text-xs font-semibold <%= s.status === 'Active' ? 'border-rose-200 bg-rose-50 text-rose-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' %>">
                  <%= s.status === 'Active' ? 'Set Inactive' : 'Set Active' %>
                </button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
