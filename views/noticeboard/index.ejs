<div class="max-w-7xl mx-auto space-y-6">
  <div class="bg-white rounded-xl shadow p-6 border border-gray-100">
    <h2 class="text-2xl font-bold text-gray-900 mb-2">Create Notice</h2>
    <p class="text-sm text-gray-500 mb-5">Publish a notice for one specific class.</p>

    <form action="/api/noticeboard/create" method="POST" class="grid gap-4 md:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" name="title" required class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Exam schedule">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Class / Batch</label>
        <select name="batchId" required class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">Select a batch</option>
          <% batches.forEach(function(batch) { %>
            <option value="<%= batch._id %>"><%= batch.name %> - <%= batch.courseType %> - <%= batch.year %></option>
          <% }) %>
        </select>
      </div>

      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-700 mb-1">Notice</label>
        <textarea name="message" rows="5" required class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Write the notice for this class"></textarea>
      </div>

      <div class="md:col-span-2">
        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-blue-700 px-5 py-2.5 font-semibold text-white hover:bg-blue-800">
          <i class="fas fa-paper-plane"></i>
          Publish Notice
        </button>
      </div>
    </form>
  </div>

  <div class="bg-white rounded-xl shadow p-6 border border-gray-100">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Recent Notices</h2>
        <p class="text-sm text-gray-500">Latest notices for all classes.</p>
      </div>
    </div>

    <div class="space-y-4">
      <% if (notices && notices.length) { %>
        <% notices.forEach(function(notice) { %>
          <div class="rounded-xl border border-gray-200 p-4 bg-gray-50">
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <h3 class="text-lg font-semibold text-gray-900"><%= notice.title %></h3>
                  <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-800">
                    <%= notice.batch ? `${notice.batch.name} - ${notice.batch.courseType} - ${notice.batch.year}` : 'Unknown Batch' %>
                  </span>
                </div>
                <p class="text-gray-700 whitespace-pre-line"><%= notice.message %></p>
                <p class="mt-2 text-xs text-gray-500">
                  Posted on <%= new Date(notice.createdAt).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %>
                  <% if (notice.createdBy) { %>
                    by <%= notice.createdBy.name || notice.createdBy.username || 'Admin' %>
                  <% } %>
                </p>
              </div>

              <form action="/api/noticeboard/delete/<%= notice._id %>" method="POST" onsubmit="return confirm('Delete this notice?')">
                <button type="submit" class="rounded-lg bg-red-600 px-4 py-2 text-white hover:bg-red-700">
                  Delete
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="rounded-xl border border-dashed border-gray-300 p-8 text-center text-gray-500">
          No notices have been published yet.
        </div>
      <% } %>
    </div>
  </div>
</div>