<style>
  .fees-new-page {
    --ink: #1f2937;
    --muted: #64748b;
    --card: #fffdf8;
    --line: #d6d3d1;
    --accent: #1e3a8a;
    --success: #166534;
    --bg1: #f4efe7;
    --bg2: #e7edf7;

    color: var(--ink);
    font-size: 17px;
    height: calc(100vh - 170px);
    overflow: hidden;
    background:
      radial-gradient(circle at 10% 10%, rgba(30, 58, 138, 0.08), transparent 36%),
      radial-gradient(circle at 90% 90%, rgba(22, 101, 52, 0.08), transparent 34%),
      linear-gradient(135deg, var(--bg1), var(--bg2));
    border-radius: 14px;
    padding: 1rem;
  }

  .fees-new-page .hero {
    letter-spacing: 0.02em;
  }

  .fees-new-page .sheet {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.9));
    border: 1px solid rgba(214, 211, 209, 0.9);
    box-shadow: 0 20px 48px rgba(15, 23, 42, 0.14);
    border-radius: 18px;
  }

  .fees-new-page .section {
    border: 1px solid var(--line);
    background: var(--card);
    border-radius: 14px;
    padding: 14px;
  }

  .fees-new-page .field {
    width: 100%;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 16px;
    background: #fff;
  }

  .fees-new-page .field:focus {
    outline: none;
    border-color: #1d4ed8;
    box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.13);
  }

  .fees-new-page .action-btn {
    background: linear-gradient(135deg, #1d4ed8, #1e3a8a);
    color: #fff;
    border-radius: 9px;
    padding: 7px 12px;
    font-size: 14px;
    font-weight: 700;
    transition: filter 150ms ease;
  }

  .fees-new-page .action-btn:hover {
    filter: brightness(1.07);
  }

  .fees-new-page .save-btn {
    background: linear-gradient(135deg, var(--success), #14532d);
    color: #fff;
    border-radius: 12px;
    padding: 11px 14px;
    font-size: 17px;
    font-weight: 700;
    width: 100%;
  }

  .fees-new-page .rupee-wrap {
    position: relative;
  }

  .fees-new-page .rupee-wrap span {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: #64748b;
    font-weight: 700;
    pointer-events: none;
  }

  .fees-new-page .rupee-wrap input {
    padding-left: 25px;
  }

  .fees-new-page .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.62);
    display: none;
    z-index: 80;
  }

  .fees-new-page .modal-backdrop.open {
    display: block;
  }

  .fees-new-page .modal-sheet {
    position: fixed;
    inset: 0;
    background: linear-gradient(180deg, #fbfdff, #f2f5fb);
    display: none;
    z-index: 90;
    overflow-y: auto;
    padding: 18px;
  }

  .fees-new-page .modal-sheet.open {
    display: block;
  }
</style>

<div class="fees-new-page">
  <div class="w-full h-full mx-auto space-y-5 flex flex-col overflow-hidden">
    <div class="sheet p-4 sm:p-7">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-6">
        <div>
          <p class="uppercase tracking-[0.2em] text-sm text-slate-500">Finance Desk</p>
          <h1 class="hero text-5xl sm:text-6xl leading-tight text-slate-800">Select Student For Fee</h1>
          <p class="text-slate-500 mt-1 text-lg">Step 1: choose an active student. Step 2: add or update fee details.</p>
        </div>
        <a href="/fees" class="text-base text-slate-700 font-semibold hover:underline">Back to Fees</a>
      </div>

      <div class="section">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
          <input id="studentSearch" type="text" placeholder="Search by name, roll number, or batch" class="field sm:max-w-md" />
          <p id="studentCount" class="text-sm text-slate-500"><%= students.length %> active students</p>
        </div>

        <div class="rounded-xl border border-slate-200 overflow-hidden">
          <div class="max-h-[58vh] overflow-y-auto overflow-x-auto">
          <table class="w-full text-base">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="p-3 text-left">Name</th>
                <th class="p-3 text-left">Roll Number</th>
                <th class="p-3 text-left">Batch</th>
                <th class="p-3 text-left">Fee Status</th>
                <th class="p-3 text-center">Action</th>
              </tr>
            </thead>
            <tbody id="studentsTableBody">
              <% students.forEach(student => { %>
                <tr
                  class="student-row border-t border-slate-200"
                  data-name="<%= student.name.toLowerCase() %>"
                  data-roll="<%= (student.rollNumber || '').toLowerCase() %>"
                  data-batch="<%= (student.batch?.name || '').toLowerCase() %>"
                >
                  <td class="p-3 font-semibold text-slate-800"><%= student.name %></td>
                  <td class="p-3 text-slate-600"><%= student.rollNumber || '-' %></td>
                  <td class="p-3 text-slate-600"><%= student.batch?.name || '-' %></td>
                  <td class="p-3">
                    <% if (studentFeeMap.has(String(student._id))) { %>
                      <span class="text-sm bg-blue-100 text-blue-700 px-2 py-1 rounded-full">Already Exists</span>
                    <% } else { %>
                      <span class="text-sm bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full">Not Added</span>
                    <% } %>
                  </td>
                  <td class="p-3 text-center">
                    <button
                      type="button"
                      class="action-btn open-fee-modal"
                      data-student-id="<%= student._id %>"
                      data-student-name="<%= student.name %>"
                      data-student-roll="<%= student.rollNumber || '-' %>"
                      data-student-batch="<%= student.batch?.name || '-' %>"
                      data-admission-fee="<%= feeByStudent[String(student._id)]?.admissionFee || 0 %>"
                      data-tuition-fee="<%= feeByStudent[String(student._id)]?.tuitionFee || 0 %>"
                      data-transport-fee="<%= feeByStudent[String(student._id)]?.transportFee || 0 %>"
                      data-other-fee="<%= feeByStudent[String(student._id)]?.otherFee || 0 %>"
                    >
                      Add Fee
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          </div>
        </div>
      </div>
    </div>

    <div class="sheet p-5 text-center text-slate-600 text-lg">
      Click <strong>Add Fee</strong> for any student to open a full-screen fee entry modal.
    </div>
  </div>

  <div id="feeModalBackdrop" class="modal-backdrop"></div>
  <div id="feeModal" class="modal-sheet" role="dialog" aria-modal="true" aria-labelledby="feeModalTitle">
    <div class="max-w-5xl mx-auto sheet p-5 sm:p-7">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-5">
        <div>
          <p class="uppercase tracking-[0.2em] text-sm text-slate-500">Fee Entry</p>
          <h2 id="feeModalTitle" class="hero text-4xl sm:text-5xl leading-tight text-slate-800">Add Fee Details</h2>
          <p id="feeStudentMeta" class="text-slate-500 mt-1 text-lg"></p>
        </div>
        <button id="closeFeeModalTop" type="button" class="action-btn">Close</button>
      </div>

      <form method="POST" action="/fees/new" class="space-y-4">
        <input type="hidden" id="modalStudentId" name="studentId" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-base font-semibold text-slate-700 mb-2" for="modalAdmissionFee">Admission Fee</label>
            <div class="rupee-wrap">
              <span>Rs</span>
              <input id="modalAdmissionFee" class="field" type="number" min="0" name="admissionFee" value="0" required />
            </div>
          </div>

          <div>
            <label class="block text-base font-semibold text-slate-700 mb-2" for="modalTuitionFee">Tuition Fee</label>
            <div class="rupee-wrap">
              <span>Rs</span>
              <input id="modalTuitionFee" class="field" type="number" min="0" name="tuitionFee" value="0" required />
            </div>
          </div>

          <div>
            <label class="block text-base font-semibold text-slate-700 mb-2" for="modalTransportFee">Transport Fee</label>
            <div class="rupee-wrap">
              <span>Rs</span>
              <input id="modalTransportFee" class="field" type="number" min="0" name="transportFee" value="0" required />
            </div>
          </div>

          <div>
            <label class="block text-base font-semibold text-slate-700 mb-2" for="modalOtherFee">Other Fee</label>
            <div class="rupee-wrap">
              <span>Rs</span>
              <input id="modalOtherFee" class="field" type="number" min="0" name="otherFee" value="0" required />
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <button id="closeFeeModalBottom" type="button" class="field font-semibold text-slate-700 bg-white">Cancel</button>
          <button type="submit" class="save-btn">Save Fee Details</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    (function () {
      const container = document.querySelector(".fees-new-page");
      if (!container) return;

      const searchInput = container.querySelector("#studentSearch");
      const rows = Array.from(container.querySelectorAll(".student-row"));
      const studentCount = container.querySelector("#studentCount");
      const openButtons = Array.from(container.querySelectorAll(".open-fee-modal"));
      const modal = container.querySelector("#feeModal");
      const modalBackdrop = container.querySelector("#feeModalBackdrop");
      const closeFeeModalTop = container.querySelector("#closeFeeModalTop");
      const closeFeeModalBottom = container.querySelector("#closeFeeModalBottom");

      const modalStudentId = container.querySelector("#modalStudentId");
      const modalStudentMeta = container.querySelector("#feeStudentMeta");
      const modalAdmissionFee = container.querySelector("#modalAdmissionFee");
      const modalTuitionFee = container.querySelector("#modalTuitionFee");
      const modalTransportFee = container.querySelector("#modalTransportFee");
      const modalOtherFee = container.querySelector("#modalOtherFee");

      if (searchInput && rows.length) {
        searchInput.addEventListener("input", () => {
          const query = searchInput.value.trim().toLowerCase();
          let visibleCount = 0;

          rows.forEach((row) => {
            const matches =
              row.dataset.name.includes(query) ||
              row.dataset.roll.includes(query) ||
              row.dataset.batch.includes(query);

            row.style.display = matches ? "" : "none";
            if (matches) visibleCount += 1;
          });

          if (studentCount) {
            studentCount.textContent = `${visibleCount} active student${visibleCount === 1 ? "" : "s"}`;
          }
        });
      }

      function closeModal() {
        if (modal) modal.classList.remove("open");
        if (modalBackdrop) modalBackdrop.classList.remove("open");
        document.body.style.overflow = "";
      }

      function openModalFromButton(button) {
        if (!button || !modal || !modalBackdrop) return;

        const studentId = button.dataset.studentId || "";
        const studentName = button.dataset.studentName || "";
        const studentRoll = button.dataset.studentRoll || "-";
        const studentBatch = button.dataset.studentBatch || "-";

        if (modalStudentId) modalStudentId.value = studentId;
        if (modalStudentMeta) {
          modalStudentMeta.textContent = `Student: ${studentName} | Roll: ${studentRoll} | Batch: ${studentBatch}`;
        }

        if (modalAdmissionFee) modalAdmissionFee.value = button.dataset.admissionFee || "0";
        if (modalTuitionFee) modalTuitionFee.value = button.dataset.tuitionFee || "0";
        if (modalTransportFee) modalTransportFee.value = button.dataset.transportFee || "0";
        if (modalOtherFee) modalOtherFee.value = button.dataset.otherFee || "0";

        modal.classList.add("open");
        modalBackdrop.classList.add("open");
        document.body.style.overflow = "hidden";
      }

      openButtons.forEach((button) => {
        button.addEventListener("click", () => openModalFromButton(button));
      });

      modalBackdrop?.addEventListener("click", closeModal);
      closeFeeModalTop?.addEventListener("click", closeModal);
      closeFeeModalBottom?.addEventListener("click", closeModal);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeModal();
      });
    })();
  </script>
</div>
