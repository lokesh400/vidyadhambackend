<div class="space-y-4">
  <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-4">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-slate-800">Date-wise Fee Table</h1>
        <p class="text-slate-500 text-sm">Select a date to view all fee payments made on that day.</p>
      </div>
      <a href="/fees" class="text-blue-700 font-semibold hover:underline">Back to Fee Dashboard</a>
    </div>

    <form method="GET" action="/fees/date-wise" class="mt-4 flex flex-col sm:flex-row gap-2 sm:items-end">
      <div>
        <label for="date" class="block text-sm font-semibold text-slate-700 mb-1">Payment Date</label>
        <input
          id="date"
          name="date"
          type="date"
          value="<%= selectedDate %>"
          required
          class="border border-slate-300 rounded-lg px-3 py-2"
        />
      </div>

      <button
        type="submit"
        class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded-lg font-semibold transition"
      >
        View Table
      </button>
    </form>

    <div class="mt-3 flex flex-wrap gap-2">
      <a href="/fees/date-wise?preset=today" class="px-3 py-1.5 rounded-lg text-sm font-semibold border <%= preset === 'today' ? 'bg-blue-700 text-white border-blue-700' : 'bg-white text-slate-700 border-slate-300 hover:bg-slate-50' %>">
        Today
      </a>
      <a href="/fees/date-wise?preset=yesterday" class="px-3 py-1.5 rounded-lg text-sm font-semibold border <%= preset === 'yesterday' ? 'bg-blue-700 text-white border-blue-700' : 'bg-white text-slate-700 border-slate-300 hover:bg-slate-50' %>">
        Yesterday
      </a>
      <a href="/fees/date-wise?preset=this-month" class="px-3 py-1.5 rounded-lg text-sm font-semibold border <%= preset === 'this-month' ? 'bg-blue-700 text-white border-blue-700' : 'bg-white text-slate-700 border-slate-300 hover:bg-slate-50' %>">
        This Month
      </a>
      <a href="/fees/date-wise" class="px-3 py-1.5 rounded-lg text-sm font-semibold border bg-white text-slate-700 border-slate-300 hover:bg-slate-50">
        Clear
      </a>
    </div>
  </div>

  <% if (hasFilter) { %>
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-4">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
        <p class="text-slate-700 font-semibold">
          Showing payments for: <span class="text-slate-900"><%= filterLabel %></span>
        </p>
        <p class="text-slate-700 font-bold">Total Collection: Rs <%= totalAmount.toLocaleString("en-IN") %></p>
      </div>

      <div class="overflow-x-auto border border-slate-200 rounded-lg">
        <table class="w-full text-sm">
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <th class="p-3 text-left">Time</th>
              <th class="p-3 text-left">Student</th>
              <th class="p-3 text-left">Roll</th>
              <th class="p-3 text-left">Batch</th>
              <th class="p-3 text-center">Amount</th>
              <th class="p-3 text-center">Mode</th>
              <th class="p-3 text-center">Receipt</th>
              <th class="p-3 text-center">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (rows.length === 0) { %>
              <tr>
                <td colspan="8" class="p-4 text-center text-slate-500">No fee payments found for this date.</td>
              </tr>
            <% } %>

            <% rows.forEach(row => { %>
              <tr class="border-t border-slate-200 hover:bg-slate-50">
                <td class="p-3"><%= new Date(row.paymentDate).toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit" }) %></td>
                <td class="p-3 font-semibold text-slate-800"><%= row.studentName %></td>
                <td class="p-3"><%= row.rollNumber %></td>
                <td class="p-3"><%= row.batchName %></td>
                <td class="p-3 text-center font-semibold">Rs <%= Number(row.amount || 0).toLocaleString("en-IN") %></td>
                <td class="p-3 text-center"><%= row.mode %></td>
                <td class="p-3 text-center"><%= row.receiptNo %></td>
                <td class="p-3 text-center">
                  <a href="/fees/student/<%= row.studentId %>" class="bg-blue-700 hover:bg-blue-800 text-white px-3 py-1.5 rounded text-xs font-semibold">
                    View Student
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>
