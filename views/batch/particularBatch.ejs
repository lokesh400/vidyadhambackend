<div class="max-w-5xl mx-auto p-6 <%= batch.isActive ? '' : 'bg-rose-50 border border-rose-200 rounded-xl' %>">

  <%- include('../flash.ejs') %>

  <!-- HEADER -->
  <h1 class="text-3xl font-bold mb-2">
    <%= batch.name %>
  </h1>

  <% if (!batch.isActive) { %>
    <p class="mb-6 inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-semibold bg-rose-100 text-rose-700 border border-rose-200">
      This batch is currently inactive
    </p>
  <% } %>

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">

    <!-- Students -->
    <div class="bg-blue-100 border-l-4 border-blue-600 p-4 rounded shadow">
      <p class="text-lg font-medium text-blue-800">
        Total Students
      </p>
      <p class="text-3xl font-bold text-blue-900">
        <%= studentsCount %>
      </p>
    </div>

    <!-- Tests -->
    <div class="bg-purple-100 border-l-4 border-purple-600 p-4 rounded shadow">
      <p class="text-lg font-medium text-purple-800">
        Total Tests Taken
      </p>
      <p class="text-3xl font-bold text-purple-900">
        <%= totalTests %>
      </p>
    </div>

    <div class="bg-emerald-100 border-l-4 border-emerald-600 p-4 rounded shadow">
      <p class="text-lg font-medium text-emerald-800">
        Active Students
      </p>
      <p class="text-3xl font-bold text-emerald-900">
        <%= activeStudentsCount %>
      </p>
    </div>

    <div class="bg-rose-100 border-l-4 border-rose-600 p-4 rounded shadow">
      <p class="text-lg font-medium text-rose-800">
        Inactive Students
      </p>
      <p class="text-3xl font-bold text-rose-900">
        <%= inactiveStudentsCount %>
      </p>
    </div>

  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
    <div class="bg-white border border-slate-200 p-4 rounded shadow-sm">
      <p class="font-semibold text-slate-800 mb-2">Batch Status</p>
      <p class="text-sm text-slate-600 mb-3">
        Current: <span class="font-semibold <%= batch.isActive ? 'text-emerald-700' : 'text-rose-700' %>"><%= batch.isActive ? 'Active' : 'Inactive' %></span>
      </p>
      <form action="/api/batches/<%= batch._id %>/set-active" method="POST" class="flex flex-wrap gap-2 items-center">
        <select name="isActive" class="border border-slate-300 rounded px-3 py-2 text-sm">
          <option value="true" <%= batch.isActive ? 'selected' : '' %>>Active</option>
          <option value="false" <%= !batch.isActive ? 'selected' : '' %>>Inactive</option>
        </select>
        <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded text-sm">Update Batch Status</button>
      </form>
    </div>

    <div class="bg-white border border-slate-200 p-4 rounded shadow-sm">
      <p class="font-semibold text-slate-800 mb-2">Students Status (All Enrolled)</p>
      <p class="text-sm text-slate-600 mb-3">Bulk update all students enrolled in this batch.</p>
      <form action="/api/batches/<%= batch._id %>/students/set-active" method="POST" class="flex flex-wrap gap-2 items-center">
        <select name="isActive" class="border border-slate-300 rounded px-3 py-2 text-sm">
          <option value="true">Set All Active</option>
          <option value="false">Set All Inactive</option>
        </select>
        <button class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded text-sm">Update All Students</button>
      </form>
    </div>
  </div>


  <!-- ACTION BUTTONS -->
  <div class="flex flex-wrap gap-4 mb-10">

    <!-- Bulk Enroll Button -->
    <button 
      onclick="document.getElementById('formModal').classList.remove('hidden')"
      class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded shadow">
      Enroll Bulk Students
    </button>

    <a href="/api/students/send/details/<%= batch._id %>" class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded shadow">
        📨 Send Student Credentials
    </a>

    <!-- Delete Batch Button -->
    <button 
      onclick="document.getElementById('deleteModal').classList.remove('hidden')"
      class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded shadow">
      Delete Batch
    </button>

    <a href="/api/batches/data/download/<%= batch._id %>"
               class="bg-yellow-500 hover:bg-yellow-600 text-white text-sm px-4 py-2 rounded-lg shadow transition">
     📄 Download Data
    </a>

  </div>


  <!-- ========================== -->
  <!--      MODAL #1 : FORM LIST  -->
  <!-- ========================== -->

  <div id="formModal" 
       class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">

    <div class="bg-white w-96 p-6 rounded shadow-lg">

      <h2 class="text-xl font-bold mb-4">
        Select Form
      </h2>

      <% forms.forEach(f => { %>
        <div class="flex justify-between items-center mb-2 p-2 border rounded">
          <span><%= f.title %></span>

          <button 
            class="bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded"
            onclick="openConfirm('<%= f._id %>')">
            Include
          </button>
        </div>
      <% }) %>

      <button 
        onclick="document.getElementById('formModal').classList.add('hidden')"
        class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 mt-4 rounded w-full">
        Close
      </button>

    </div>
  </div>


  <!-- ============================== -->
  <!--      MODAL #2 : CONFIRM FORM   -->
  <!-- ============================== -->

  <div id="confirmModal" 
       class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">

    <div class="bg-white w-80 p-6 rounded shadow-lg">

      <h2 class="text-lg font-bold mb-4">
        Confirm Import?
      </h2>

      <form method="POST" id="confirmForm">
        <button class="bg-blue-600 hover:bg-blue-700 text-white w-full py-2 rounded">
          Confirm
        </button>
      </form>

      <button 
        onclick="document.getElementById('confirmModal').classList.add('hidden')"
        class="bg-gray-600 hover:bg-gray-700 text-white w-full py-2 mt-3 rounded">
        Cancel
      </button>

    </div>
  </div>


  <!-- =============================== -->
  <!--      MODAL #3 : DELETE BATCH    -->
  <!-- =============================== -->

  <div id="deleteModal" 
       class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">

    <div class="bg-white w-80 p-6 rounded shadow-lg">

      <h2 class="text-lg font-bold mb-4 text-red-600">
        Delete Batch Permanently?
      </h2>

      <p class="text-gray-700 mb-4">
        This will delete this batch AND all its student accounts. This action cannot be undone.
      </p>

      <form action="/api/batches/<%= batch._id %>/delete" method="POST">
        <button class="bg-red-600 hover:bg-red-700 text-white w-full py-2 rounded">
          Delete Batch
        </button>
      </form>

      <button 
        onclick="document.getElementById('deleteModal').classList.add('hidden')"
        class="bg-gray-600 hover:bg-gray-700 text-white w-full py-2 mt-3 rounded">
        Cancel
      </button>

    </div>
  </div>

</div>


<!-- =============================== -->
<!--          JAVASCRIPT            -->
<!-- =============================== -->

<script>
  function openConfirm(formId) {
    document.getElementById('confirmModal').classList.remove('hidden');
    document.getElementById('formModal').classList.add('hidden');

    document.getElementById('confirmForm').action =
      "/forms/" + formId + "/import/<%= batch._id %>";
  }
</script>
