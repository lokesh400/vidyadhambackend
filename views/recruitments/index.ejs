<section class="mb-6 rounded-2xl border border-slate-200 bg-gradient-to-r from-teal-50 via-white to-amber-50 p-5 md:p-7 shadow-sm">
  <div class="flex items-center justify-between gap-4 flex-wrap">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 tracking-tight">Recruitments</h2>
      <p class="text-sm text-slate-600 mt-1">Manage job posts and share openings with candidates.</p>
      <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-white border border-slate-200 px-3 py-1 text-xs font-semibold text-slate-700">
        <span class="h-2 w-2 rounded-full bg-teal-600"></span>
        <span><%= recruitments.length %> total posting<%= recruitments.length === 1 ? '' : 's' %></span>
      </div>
    </div>
    <a href="/admin/recruitments/new" class="inline-flex items-center rounded-lg bg-teal-700 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-800">
      + Create Recruitment
    </a>
  </div>
</section>

<section class="overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm">
  <table class="w-full min-w-[980px] text-sm">
    <thead class="bg-slate-50 text-slate-700">
      <tr>
        <th class="px-4 py-3 text-left font-semibold">Title</th>
        <th class="px-4 py-3 text-left font-semibold">Department</th>
        <th class="px-4 py-3 text-left font-semibold">Location</th>
        <th class="px-4 py-3 text-left font-semibold">Applications</th>
        <th class="px-4 py-3 text-left font-semibold">Status</th>
        <th class="px-4 py-3 text-left font-semibold">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% if (!recruitments.length) { %>
        <tr>
          <td colspan="6" class="px-4 py-10 text-center text-slate-500">No recruitment postings created yet.</td>
        </tr>
      <% } %>

      <% recruitments.forEach((r) => { %>
        <tr class="hover:bg-slate-50/80 transition-colors">
          <td class="px-4 py-4">
            <p class="font-semibold text-slate-900"><%= r.title %></p>
          </td>
          <td class="px-4 py-4 text-slate-700"><%= r.department %></td>
          <td class="px-4 py-4 text-slate-700"><%= r.location %></td>
          <td class="px-4 py-4">
            <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= r.applicationCount %></span>
          </td>
          <td class="px-4 py-4">
            <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold <%= r.status === 'Open' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
              <%= r.status %>
            </span>
          </td>
          <td class="px-4 py-4">
            <div class="flex items-center gap-2">
              <a href="/admin/recruitments/<%= r._id %>" class="rounded-md border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100">View</a>
              <a href="/admin/recruitments/<%= r._id %>/edit" class="rounded-md border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-700 hover:bg-amber-100">Edit</a>
              <button
                type="button"
                class="rounded-md border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-semibold text-emerald-700 hover:bg-emerald-100 share-recruitment-btn"
                data-share-url="/recruitments/<%= r._id %>"
                data-share-title="<%= r.title %>"
              >
                Share
              </button>
              <form action="/admin/recruitments/<%= r._id %>/delete" method="POST" onsubmit="return confirm('Delete this recruitment and all applications?');">
                <button class="rounded-md border border-rose-200 bg-rose-50 px-3 py-1.5 text-xs font-semibold text-rose-700 hover:bg-rose-100" type="submit">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<p id="shareRecruitmentMsg" class="text-sm font-medium text-emerald-700 mt-4 hidden"></p>

<script>
  const shareButtons = document.querySelectorAll(".share-recruitment-btn");
  const shareMsg = document.getElementById("shareRecruitmentMsg");

  const setShareMessage = (text, isError = false) => {
    if (!shareMsg) return;
    shareMsg.textContent = text;
    shareMsg.classList.remove("hidden", "text-emerald-700", "text-rose-700");
    shareMsg.classList.add(isError ? "text-rose-700" : "text-emerald-700");
  };

  shareButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const sharePath = button.dataset.shareUrl;
      const shareTitle = button.dataset.shareTitle || "Recruitment";
      const shareUrl = `${window.location.origin}${sharePath}`;

      try {
        if (navigator.share) {
          await navigator.share({
            title: `${shareTitle} - VidyaDham Mandir Careers`,
            text: "Check this recruitment opening at VidyaDham Mandir",
            url: shareUrl,
          });
          setShareMessage("Recruitment link shared successfully.");
          return;
        }

        await navigator.clipboard.writeText(shareUrl);
        setShareMessage("Recruitment link copied. You can paste and share it.");
      } catch (error) {
        setShareMessage("Could not share automatically. Please copy the public recruitment URL manually.", true);
      }
    });
  });
</script>
