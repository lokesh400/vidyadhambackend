<section class="mb-5 rounded-2xl border border-slate-200 bg-gradient-to-r from-teal-50 via-white to-amber-50 p-5 md:p-7 shadow-sm max-w-5xl">
  <h2 class="text-3xl font-bold text-slate-900 tracking-tight">Create Recruitment</h2>
  <p class="mt-2 text-sm text-slate-600">Publish a new opening with complete details for candidates.</p>
</section>

<form action="/admin/recruitments/add" method="POST" enctype="multipart/form-data" class="max-w-5xl rounded-2xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm space-y-6">
  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Job Title</label>
      <input name="title" placeholder="e.g. Mathematics Faculty" class="w-full border border-slate-300 p-2.5 rounded-lg" required />
    </div>
    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Department</label>
      <input name="department" placeholder="e.g. Academics" class="w-full border border-slate-300 p-2.5 rounded-lg" />
    </div>

    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Experience</label>
      <input name="experience" placeholder="e.g. 2-4 years" class="w-full border border-slate-300 p-2.5 rounded-lg" />
    </div>
    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Salary Range</label>
      <input name="salaryRange" placeholder="e.g. 4LPA - 6LPA" class="w-full border border-slate-300 p-2.5 rounded-lg" />
    </div>

    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Location</label>
      <input name="location" placeholder="e.g. Jaipur" class="w-full border border-slate-300 p-2.5 rounded-lg" required />
    </div>

    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Employment Type</label>
      <select name="employmentType" class="w-full border border-slate-300 p-2.5 rounded-lg">
        <option value="Full-time">Full-time</option>
        <option value="Part-time">Part-time</option>
        <option value="Contract">Contract</option>
        <option value="Internship">Internship</option>
      </select>
    </div>

    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Openings</label>
      <input type="number" min="1" name="openings" value="1" placeholder="Openings" class="w-full border border-slate-300 p-2.5 rounded-lg" />
    </div>
    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Last Date To Apply</label>
      <input type="date" name="lastDateToApply" class="w-full border border-slate-300 p-2.5 rounded-lg" />
    </div>
  </div>

  <div>
    <label class="block mb-1 text-sm font-semibold text-slate-700">Job Description</label>
    <textarea name="description" placeholder="Write role responsibilities, requirements, and expectations" class="w-full border border-slate-300 p-3 rounded-lg h-36" required></textarea>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Job Description PDF</label>
      <input type="file" name="jd" accept=".pdf" class="w-full text-sm" />
    </div>

    <div>
      <label class="block mb-1 text-sm font-semibold text-slate-700">Status</label>
      <select name="status" class="w-full border border-slate-300 p-2.5 rounded-lg">
        <option value="Open">Open</option>
        <option value="Closed">Closed</option>
      </select>
    </div>
  </div>

  <button class="inline-flex items-center rounded-lg bg-teal-700 px-6 py-2.5 text-sm font-semibold text-white hover:bg-teal-800" type="submit">
    Save Recruitment
  </button>
</form>
