<div class="space-y-6">
  <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
    <div class="flex justify-between items-start gap-6">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 mb-2 tracking-tight"><%= recruitment.title %></h1>
        <p class="text-slate-600 mb-4 text-sm md:text-base">
          <strong>Department:</strong> <%= recruitment.department %> |
          <strong>Location:</strong> <%= recruitment.location %> |
          <strong>Type:</strong> <%= recruitment.employmentType || 'Full-time' %>
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/admin/recruitments/<%= recruitment._id %>/edit" class="px-4 py-2 rounded-lg border border-amber-200 bg-amber-50 text-amber-700 text-sm font-semibold">Edit</a>
        <a href="/recruitments/<%= recruitment._id %>" target="_blank" class="px-4 py-2 rounded-lg border border-sky-200 bg-sky-50 text-sky-700 text-sm font-semibold">Public Page</a>
        <button
          id="shareRecruitmentBtn"
          type="button"
          class="px-4 py-2 rounded-lg border border-emerald-200 bg-emerald-50 text-emerald-700 text-sm font-semibold"
          data-share-url="/recruitments/<%= recruitment._id %>"
        >
          Share
        </button>
      </div>
    </div>
    <p id="shareRecruitmentMsg" class="text-sm font-medium text-emerald-700 mt-3 hidden"></p>

    <div class="mb-4">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wide <%= recruitment.status === 'Open' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
        <%= recruitment.status %>
      </span>
    </div>

    <h2 class="text-lg font-bold mt-4 text-slate-900">Job Description</h2>
    <p class="text-slate-700 whitespace-pre-line mt-2 leading-relaxed"><%= recruitment.description %></p>

    <div class="mt-5 grid md:grid-cols-2 gap-3 text-sm text-slate-700">
      <p class="rounded-lg border border-slate-200 bg-slate-50 p-3"><strong>Experience:</strong> <%= recruitment.experience || 'Not specified' %></p>
      <p class="rounded-lg border border-slate-200 bg-slate-50 p-3"><strong>Salary:</strong> <%= recruitment.salaryRange || 'Not specified' %></p>
      <p class="rounded-lg border border-slate-200 bg-slate-50 p-3"><strong>Openings:</strong> <%= recruitment.openings || 1 %></p>
      <p class="rounded-lg border border-slate-200 bg-slate-50 p-3"><strong>Last Date:</strong> <%= recruitment.lastDateToApply ? new Date(recruitment.lastDateToApply).toLocaleDateString() : 'Not specified' %></p>
    </div>

    <% if (recruitment.jdFile) { %>
      <div class="mt-6">
        <a href="/<%= recruitment.jdFile %>" target="_blank" class="inline-flex items-center rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Download Job Description (PDF)</a>
      </div>
    <% } %>
  </div>

  <%
    const statusTabs = ["All", "New", "In Review", "Shortlisted", "Rejected", "Hired"];
    const currentFilters = filters || { status: "All", sort: "newest" };
    const buildQuery = (overrides = {}) => {
      const next = {
        status: currentFilters.status || "All",
        sort: currentFilters.sort || "newest",
        ...overrides,
      };

      const parts = [];
      if (next.status && next.status !== "All") parts.push(`status=${encodeURIComponent(next.status)}`);
      if (next.sort && next.sort !== "newest") parts.push(`sort=${encodeURIComponent(next.sort)}`);
      return parts.length ? `?${parts.join("&")}` : "";
    };
    const currentPath = `/admin/recruitments/${recruitment._id}`;
    const currentFullPath = `${currentPath}${buildQuery({})}`;
  %>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
      <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Applications (<%= applications.length %>)</h2>

      <form method="GET" action="/admin/recruitments/<%= recruitment._id %>" class="flex flex-wrap items-center gap-2">
        <% if (currentFilters.status && currentFilters.status !== 'All') { %>
          <input type="hidden" name="status" value="<%= currentFilters.status %>" />
        <% } %>

        <select name="sort" class="border border-slate-300 rounded-lg px-3 py-2 text-sm">
          <option value="newest" <%= currentFilters.sort === 'newest' ? 'selected' : '' %>>Newest</option>
          <option value="oldest" <%= currentFilters.sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
        </select>
        <button type="submit" class="rounded-lg bg-teal-700 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-800">Apply</button>
        <a href="/admin/recruitments/<%= recruitment._id %>" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Reset</a>
      </form>
    </div>

    <div class="mb-4">
      <input
        id="applicationsSearchInput"
        type="text"
        placeholder="Search candidate name or email"
        class="border border-slate-300 rounded-lg px-3 py-2 text-sm w-full md:w-80"
      />
      <p id="applicationsSearchMeta" class="text-xs text-slate-500 mt-1"></p>
    </div>

    <div class="flex flex-wrap gap-2 mb-5">
      <% statusTabs.forEach((tab) => { %>
        <a
          href="<%= currentPath + buildQuery({ status: tab }) %>"
          class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-semibold <%= currentFilters.status === tab ? 'bg-teal-700 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200' %>"
        >
          <span><%= tab %></span>
          <span class="rounded-full <%= currentFilters.status === tab ? 'bg-white/20 text-white' : 'bg-white text-slate-700' %> px-2 py-0.5"><%= statusCounts?.[tab] || 0 %></span>
        </a>
      <% }) %>
    </div>

    <% if (!applications.length) { %>
      <p class="text-slate-500">No applications submitted yet.</p>
    <% } %>

    <% if (applications.length) { %>
      <div class="overflow-x-auto rounded-xl border border-slate-200">
        <table class="w-full min-w-[1250px] text-sm">
          <thead class="bg-slate-50 text-slate-700">
            <tr>
              <th class="px-4 py-3 text-left font-semibold">Candidate</th>
              <th class="px-4 py-3 text-left font-semibold">Experience</th>
              <th class="px-4 py-3 text-left font-semibold">Company / CTC</th>
              <th class="px-4 py-3 text-left font-semibold">Notice</th>
              <th class="px-4 py-3 text-left font-semibold">Resume</th>
              <th class="px-4 py-3 text-left font-semibold">Applied On</th>
              <th class="px-4 py-3 text-left font-semibold">Status</th>
              <th class="px-4 py-3 text-left font-semibold">Admin Notes</th>
              <th class="px-4 py-3 text-left font-semibold">Action</th>
            </tr>
          </thead>
          <tbody id="applicationsTableBody" class="divide-y divide-slate-100 bg-white">
            <% applications.forEach((app) => { %>
              <tr
                class="hover:bg-slate-50/80 align-top application-row"
                data-candidate-name="<%= (app.fullName || '').toLowerCase().replace(/"/g, '&quot;') %>"
                data-candidate-email="<%= (app.email || '').toLowerCase().replace(/"/g, '&quot;') %>"
              >
                <td class="px-4 py-4">
                  <p class="font-semibold text-slate-900"><%= app.fullName %></p>
                  <p class="text-xs text-slate-600 mt-1"><%= app.email %></p>
                  <p class="text-xs text-slate-600"><%= app.phone %></p>
                </td>
                <td class="px-4 py-4 text-slate-700"><%= app.totalExperience || 'N/A' %></td>
                <td class="px-4 py-4 text-slate-700">
                  <p><%= app.currentCompany || 'N/A' %></p>
                  <p class="text-xs text-slate-500 mt-1">Current: <%= app.currentCTC || 'N/A' %></p>
                  <p class="text-xs text-slate-500">Expected: <%= app.expectedCTC || 'N/A' %></p>
                </td>
                <td class="px-4 py-4 text-slate-700"><%= app.noticePeriod || 'N/A' %></td>
                <td class="px-4 py-4">
                  <a href="/admin/recruitments/<%= recruitment._id %>/applications/<%= app._id %>/resume" target="_blank" class="inline-flex rounded-md border border-sky-200 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-700 hover:bg-sky-100">View Resume</a>
                </td>
                <td class="px-4 py-4 text-slate-600"><%= new Date(app.createdAt).toLocaleString() %></td>
                <td class="px-4 py-4">
                  <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold <%= app.status === 'Hired' ? 'bg-emerald-100 text-emerald-700' : app.status === 'Rejected' ? 'bg-rose-100 text-rose-700' : app.status === 'Shortlisted' ? 'bg-blue-100 text-blue-700' : app.status === 'In Review' ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-700' %>">
                    <%= app.status %>
                  </span>
                </td>
                <td class="px-4 py-4 max-w-[260px]">
                  <p class="text-slate-700 whitespace-pre-line"><%= app.adminNotes || '-' %></p>
                  <% if (app.coverLetter) { %>
                    <details class="mt-2 text-xs text-slate-600">
                      <summary class="cursor-pointer font-semibold">View Cover Letter</summary>
                      <p class="mt-1 whitespace-pre-line"><%= app.coverLetter %></p>
                    </details>
                  <% } %>
                </td>
                <td class="px-4 py-4">
                  <form action="/admin/recruitments/<%= recruitment._id %>/applications/<%= app._id %>/status" method="POST" class="space-y-2 min-w-[200px]">
                    <input type="hidden" name="returnTo" value="<%= currentFullPath %>" />
                    <select name="status" class="w-full border border-slate-300 p-2 rounded-lg text-xs">
                      <% ['New', 'In Review', 'Shortlisted', 'Rejected', 'Hired'].forEach((s) => { %>
                        <option value="<%= s %>" <%= app.status === s ? 'selected' : '' %>><%= s %></option>
                      <% }) %>
                    </select>
                    <input name="adminNotes" value="<%= app.adminNotes || '' %>" class="w-full border border-slate-300 p-2 rounded-lg text-xs" placeholder="Add notes" />
                    <button type="submit" class="w-full bg-teal-700 text-white px-3 py-2 rounded-lg text-xs font-semibold hover:bg-teal-800">Update</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <p id="applicationsNoMatch" class="hidden text-slate-500 mt-3">No applications match your search.</p>
    <% } %>
  </div>
</div>

<script>
  const shareBtn = document.getElementById("shareRecruitmentBtn");
  const shareMsg = document.getElementById("shareRecruitmentMsg");

  const setShareMessage = (text, isError = false) => {
    if (!shareMsg) return;
    shareMsg.textContent = text;
    shareMsg.classList.remove("hidden", "text-emerald-700", "text-rose-700");
    shareMsg.classList.add(isError ? "text-rose-700" : "text-emerald-700");
  };

  shareBtn?.addEventListener("click", async () => {
    const sharePath = shareBtn.dataset.shareUrl;
    const shareUrl = `${window.location.origin}${sharePath}`;

    try {
      if (navigator.share) {
        await navigator.share({
          title: "<%= recruitment.title %> - VidyaDham Mandir Careers",
          text: "Check this recruitment opening at VidyaDham Mandir",
          url: shareUrl,
        });
        setShareMessage("Recruitment link shared successfully.");
        return;
      }

      await navigator.clipboard.writeText(shareUrl);
      setShareMessage("Recruitment link copied. You can paste and share it.");
    } catch (error) {
      setShareMessage("Could not share automatically. Please copy the public recruitment URL manually.", true);
    }
  });

  const searchInput = document.getElementById("applicationsSearchInput");
  const tableBody = document.getElementById("applicationsTableBody");
  const noMatchLabel = document.getElementById("applicationsNoMatch");
  const searchMeta = document.getElementById("applicationsSearchMeta");

  const applicationRows = tableBody ? Array.from(tableBody.querySelectorAll(".application-row")) : [];
  const totalRows = applicationRows.length;

  const renderSearchMeta = (visibleCount, query) => {
    if (!searchMeta) return;
    if (!query) {
      searchMeta.textContent = `Showing all ${totalRows} applications`;
      return;
    }
    searchMeta.textContent = `Showing ${visibleCount} of ${totalRows} applications for "${query}"`;
  };

  const filterApplications = () => {
    if (!searchInput || !tableBody) return;
    const query = searchInput.value.trim().toLowerCase();
    let visibleCount = 0;

    applicationRows.forEach((row) => {
      const name = row.dataset.candidateName || "";
      const email = row.dataset.candidateEmail || "";
      const matched = !query || name.includes(query) || email.includes(query);
      row.classList.toggle("hidden", !matched);
      if (matched) visibleCount += 1;
    });

    if (noMatchLabel) {
      noMatchLabel.classList.toggle("hidden", visibleCount !== 0 || !query);
    }

    renderSearchMeta(visibleCount, query);
  };

  if (searchInput) {
    searchInput.addEventListener("input", filterApplications);
    renderSearchMeta(totalRows, "");
  }
</script>
