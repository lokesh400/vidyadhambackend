<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resume Preview - <%= candidateName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen">
  <div class="max-w-6xl mx-auto p-4 md:p-6">
    <div class="bg-white rounded-xl shadow border border-slate-200 p-4 mb-4 flex flex-wrap items-center justify-between gap-3">
      <h1 class="text-lg md:text-xl font-semibold text-slate-900">Resume Preview - <%= candidateName %></h1>
      <a href="<%= resumeUrl %>" target="_blank" class="px-4 py-2 rounded-lg border border-slate-300 text-sm font-semibold text-slate-700 hover:bg-slate-50">Open Original PDF</a>
    </div>

    <div class="bg-white rounded-xl shadow border border-slate-200 overflow-hidden">
      <iframe
        src="<%= inlineResumeUrl %>"
        class="w-full h-[82vh]"
        title="Resume PDF Preview"
      ></iframe>
    </div>
  </div>
</body>
</html>
